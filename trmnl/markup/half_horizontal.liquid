{% comment %}
  TTC Next Vehicle — HALF HORIZONTAL layout (800x240)
  Shows the soonest arrival per direction, side by side.
  See full.liquid for data-shape notes.
{% endcomment %}

<div class="layout layout--row gap--medium">
  <div id="ttc-arrivals" class="grid grid--cols-2 gap--medium"></div>
  <div id="ttc-empty" class="hidden text--center">
    <span class="value">No vehicles due</span>
  </div>
</div>

<div class="title_bar">
  <span class="title">TTC</span>
  <span id="ttc-stop-title" class="instance">Stop {{ stop_id }}</span>
</div>

<script type="application/json" id="ttc-data">{{ predictions | json }}</script>
<script type="application/json" id="ttc-settings">
  { "direction": "{{ direction | default: 'both' }}", "max": 2 }
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var asArray = function (node) {
    if (node === undefined || node === null) return [];
    return Array.isArray(node) ? [node].flat() : [node];
  };

  var data = JSON.parse(document.getElementById("ttc-data").textContent || "null");
  var settings = JSON.parse(document.getElementById("ttc-settings").textContent);

  var matchesDirection = function (title) {
    if (settings.direction === "east_north") return /^(east|north)/i.test(title);
    if (settings.direction === "west_south") return /^(west|south)/i.test(title);
    return true;
  };

  var rows = [];
  var stopTitle = null;

  asArray(data).forEach(function (route) {
    if (!route) return;
    stopTitle = stopTitle || route.stopTitle;
    if (!route.direction) return; // route serves this stop but has no service now
    asArray(route.direction).forEach(function (dir) {
      if (!matchesDirection(dir.title || "")) return;
      var preds = asArray(dir.prediction).slice(0, settings.max);
      if (preds.length === 0) return;
      var shortDir = (dir.title || "").split(" ")[0]; // "East - 501 Queen…" -> "East"
      rows.push({
        route: (route.routeTitle || "").split("-")[0], // "501-Queen" -> "501"
        heading: shortDir,
        minutes: preds.map(function (p) { return parseInt(p.minutes, 10); })
      });
    });
  });

  if (stopTitle) {
    document.getElementById("ttc-stop-title").textContent = stopTitle;
  }

  var listEl = document.getElementById("ttc-arrivals");
  if (rows.length === 0) {
    document.getElementById("ttc-empty").classList.remove("hidden");
    return;
  }

  rows.sort(function (a, b) { return a.minutes[0] - b.minutes[0]; });

  rows.slice(0, 2).forEach(function (row) {
    var first = row.minutes[0];
    var item = document.createElement("div");
    item.className = "item";
    item.innerHTML =
      '<div class="content">' +
        '<span class="value value--large value--tnums">' +
          (first === 0 ? "Due" : first + '<span class="value value--small"> min</span>') +
        "</span>" +
        '<span class="label label--small">' + row.route + " " + row.heading + "</span>" +
      "</div>";
    listEl.appendChild(item);
  });
});
</script>
